# =================================================================
# .gitignore for Nihongo IT Private Project
# Comprehensive coverage for: Kotlin/Spring Boot, Vue.js, Python, Docker, PostgreSQL
# =================================================================

# ========================
# CRITICAL PROJECT FILES TO IGNORE
# ========================

### Database Data (NEVER commit actual database data) ###
postgres-data/
**/postgres-data/
*.sql
!ddl/*.sql
!**/db/migration/*.sql
db-backups/*.sql
!db-backups/drop_all_tables.sql

### Binary Executables ###
cloud-sql-proxy.*
*.linux.amd64
*.exe
*.bin

### Sensitive Configuration ###
.env
.env.*
!.env.example
!.env.template
!.env.sample

# ========================
# BUILD SYSTEMS & ARTIFACTS
# ========================

### Gradle (Kotlin/Spring Boot Services) ###
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties
**/build/
.gradletasknamecache

### Maven (alternative build system) ###
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

### Node.js & NPM (Frontend) ###
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.npm
.yarn-integrity

### Frontend Build Outputs ###
frontend/dist/
frontend/dist-ssr/
frontend/coverage/
**/dist/
**/coverage/

