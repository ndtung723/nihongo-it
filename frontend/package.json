{
  "name": "nihongo-it-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview --port 5173",
    "test:unit": "vitest",
    "test:coverage": "vitest run --coverage",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "prepare": "cd .. && husky"
  },
  "lint-staged": {
    "src/**/*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,scss,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@vueuse/core": "^13.1.0",
    "axios": "^1.6.2",
    "chart.js": "^4.4.9",
    "date-fns": "^4.1.0",
    "jwt-decode": "^4.0.0",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.43.1",
    "pinia": "^3.0.1",
    "recorder-js": "^1.0.7",
    "sass": "^1.99.0",
    "vee-validate": "^4.15.0",
    "vue": "^3.5.13",
    "vue-chartjs": "^5.2.0",
    "vue-facing-decorator": "^3.0.4",
    "vue-i18n": "^9.8.0",
    "vue-router": "^4.5.0",
    "vue-toast-notification": "^3.1.3",
    "vue-tooltip": "^0.1.0",
    "vue3-google-login": "^2.0.33",
    "vuedraggable": "^4.1.0",
    "vuetify": "^3.7.0-beta.1",
    "wanakana": "^5.3.1",
    "yup": "^1.3.2"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/lodash": "^4.17.16",
    "@types/node": "^22.13.9",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitejs/plugin-vue-jsx": "^4.1.1",
    "@vitest/coverage-v8": "^3.0.8",
    "@vitest/eslint-plugin": "^1.1.36",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.21.0",
    "eslint-plugin-vue": "~10.0.0",
    "husky": "^9.1.7",
    "jiti": "^2.4.2",
    "jsdom": "^26.0.0",
    "lint-staged": "^17.0.2",
    "npm-run-all2": "^7.0.2",
    "prettier": "3.5.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "start-server-and-test": "^2.0.10",
    "typescript": "~5.8.0",
    "vite": "^6.2.1",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^7.7.2",
    "vite-plugin-vuetify": "^2.1.0",
    "vitest": "^3.0.8",
    "vue-tsc": "^2.2.8"
  }
}
