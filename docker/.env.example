# =============================================================
# Nihongo IT — Local Development Environment
# DO NOT COMMIT this file. It is listed in .gitignore.
# Copy .env.example to .env and fill in your values.
# =============================================================

# Database
DB_USERNAME=postgres
DB_PASSWORD=NihongoIT2024!
POSTGRES_DB=NihongoIT
DB_URL=jdbc:postgresql://postgres:5433/NihongoIT

# PgAdmin
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=root

# JWT — change this in production (min 64 chars, random)
JWT_SECRET=local-dev-jwt-secret-nihongo-it-change-in-production-must-be-at-least-64-chars!!

# OpenAI — set your own key for AI features
OPENAI_API_KEY=sk-your-openai-key-here

# Mail — Gmail App Password (16 chars, no spaces)
MAIL_USERNAME=no.reply.nihongo.it@gmail.com
MAIL_PASSWORD=your-gmail-app-password-here

# Google OAuth2 — set your own credentials for Google login
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret

# Frontend URL — used by backend services for email links, redirects, etc.
# During the Next.js migration window, point this at the canonical user-facing app
# (3000 = Next.js frontend-user). The legacy Vue dev server (5173) is no longer
# the source of truth.
APP_FRONTEND_URL=http://localhost:3000

# CORS — gateway whitelist. Defaults in api-gateway already include all three
# (5173, 3000, 3002) for local development. Override for staging/production.
# CORS_ALLOWED_ORIGINS=https://nihongo-it.com,https://admin.nihongo-it.com

# Next.js public env vars (baked into client bundle at build time).
# NEXT_PUBLIC_API_BASE_URL must be the BROWSER-facing URL — what the user's
# browser resolves to — NOT the docker-network internal hostname.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Python Service
PYTHON_SERVICE_URL=http://python:8000

# Internal API Key — used by ai-service to authenticate calls to python service
INTERNAL_API_KEY=change-this-to-a-random-secret-string

# Grafana
GRAFANA_PASSWORD=admin
